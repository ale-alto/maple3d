# Copy to .env for local overrides. All optional.

# PartyKit server the client connects to (host[:port], no protocol).
# Default: <current-hostname>:1999 (local `npm run mp` server).
# Production builds set this to the deployed partykit.dev host.
# VITE_MP_HOST=maple3d-world.USERNAME.partykit.dev

# "1" = multiplayer on by default (?mp=0 opts out). Unset = opt-in via ?mp=1.
# VITE_MP_DEFAULT=1
